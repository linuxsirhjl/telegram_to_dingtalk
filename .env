# ==================== Telegram 配置 ====================
# 从 https://my.telegram.org 获取
TELEGRAM_API_ID=xxxxxx
TELEGRAM_API_HASH=xxxxxxxxxx
# 你的 Telegram 手机号（带国际区号，如 +86）
TELEGRAM_PHONE=+91xxxxxxxxx

# ==================== 钉钉配置 ====================
# 从钉钉群机器人设置中获取
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=af701b2028c23bc23ebd7fb675fab308cd91988e01ecce037a401xxxxxxxxx

# 钉钉机器人安全设置
# 方式1：加签（推荐）- 填写密钥
# 方式2：自定义关键词 - 在钉钉设置关键词为"Telegram"（程序已自动包含此关键词）
# 如果使用了"加签"安全设置，填写密钥；如果使用关键词方式，留空即可
DINGTALK_SECRET=

# ==================== 群组配置 ====================
# 可以是群组用户名（如 @groupname）或群组 ID（数字）
# 多个群组用逗号分隔，例如: @group1,@group2,-1001234567890
TELEGRAM_GROUPS=@TwtVideoOfChina

# 检查间隔（秒），默认 60 秒
# 3600 秒 = 1 小时
CHECK_INTERVAL=3600

# ==================== 代理配置（Clash）====================
# Clash 使用 HTTP 代理
PROXY_TYPE=http
PROXY_HOST=127.0.0.1
PROXY_PORT=7890

# ==================== Cloudflare R2 图床配置 ====================
# 从 twitter_weasy 复制的配置
R2_ENDPOINT_URL=https://xxxxxxxxxxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=d2fd4af451322ba18936a333xxxxxxxx
R2_SECRET_ACCESS_KEY=fc1db38d2d4b3cfd1de260725b9ac8405d9b258fe5ac09e8cd814bxxxxxxxx
R2_BUCKET=img-bed
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ==================== 媒体下载配置 ====================
DOWNLOAD_MEDIA=true
MEDIA_DIR=downloads
MAX_VIDEO_SIZE_MB=20
# 如果代理需要认证，填写用户名和密码；否则留空
PROXY_USERNAME=
PROXY_PASSWORD=
