# Telegram 配置
# 从 https://my.telegram.org 获取
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
# 你的 Telegram 手机号（带国际区号，如 +86）
TELEGRAM_PHONE=+86your_phone_number

# 钉钉 Webhook 配置
# 从钉钉群机器人设置中获取
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your_access_token_here

# 钉钉机器人安全设置
# 方式1：加签（推荐）- 填写密钥
# 方式2：自定义关键词 - 在钉钉设置关键词为"Telegram"（程序已自动包含此关键词）
# 如果使用了"加签"安全设置，填写密钥；如果使用关键词方式，留空即可
DINGTALK_SECRET=

# 监控的 Telegram 群组
# 可以是群组用户名（如 @groupname）或群组 ID（数字）
# 多个群组用逗号分隔，例如: @group1,@group2,-1001234567890
TELEGRAM_GROUPS=@your_group_name

# 检查间隔（秒），默认 60 秒
CHECK_INTERVAL=60

# 代理配置（可选，如果无法直连 Telegram 则需要配置）
# 代理类型: socks5, http, https
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=1080
# 如果代理需要认证，填写用户名和密码；否则留空
PROXY_USERNAME=
PROXY_PASSWORD=

# ==================== 媒体下载配置 ====================
# 是否下载视频等媒体文件
DOWNLOAD_MEDIA=true
# 媒体文件保存目录
MEDIA_DIR=downloads
# 最大视频大小（MB），钉钉限制通常为 20MB
MAX_VIDEO_SIZE_MB=20

# ==================== Cloudflare R2 图床配置 ====================
# 与 twitter_weasy 配置完全相同
# Cloudflare R2（S3 兼容）图床
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=your_bucket_name
R2_PUBLIC_BASE_URL=https://your_public_domain.r2.dev
